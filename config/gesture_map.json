    "_legacy_right": {
        "One Finger":    "open_brave",
        "Two Fingers":   "open_apple_music",
        "Ring and Pinky":"next_track",
        "Pinky":         "prev_track"
    },
    "_legacy_left": {
        "One Finger":    "volume_up",
        "Two Fingers":   "volume_down",
        "Three Fingers": "mute",
        "Pinky":         "play_pause"
    }
